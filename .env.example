# Server-side key for the Vercel serverless proxy (api/ai.js).
# NEVER prefix with VITE_ — that would embed it in the browser bundle.
ANTHROPIC_KEY=your-api-key-here

# Optional: local dev fallback when NOT using `vercel dev`.
# This IS embedded in the browser, so only use for local development.
# Leave blank in production.
VITE_ANTHROPIC_KEY=
