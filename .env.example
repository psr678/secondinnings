# ── Anthropic API (required) ─────────────────────────────────────────────────
# Server-side key for the Vercel serverless proxy (api/ai.js).
# NEVER prefix with VITE_ — that would embed it in the browser bundle.
ANTHROPIC_KEY=your-api-key-here

# ── Upstash Redis — rate limiting (recommended) ───────────────────────────────
# Create a free database at https://console.upstash.com → Redis → Create Database
# Then copy the REST URL and token from the "REST API" section.
# If these are missing, rate limiting is skipped (fail-open).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── Local dev fallback (optional) ────────────────────────────────────────────
# Only used when running plain `npm run dev` without Vercel CLI.
# This IS embedded in the browser — never set in production.
VITE_ANTHROPIC_KEY=
